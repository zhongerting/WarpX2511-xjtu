warpx.abort_on_warning_threshold = medium
warpx.serialize_initial_conditions = 0
warpx.do_dynamic_scheduling = 0
particles.do_tiling = 0


#################################
##### TIME-DEPENDENT B (particle loader) #####
#################################
# Choose omega so that cos(omega * (max_step * const_dt)) = 0.5
#   => omega = (pi/3) / (max_step * const_dt)
my_constants.phase_B = 0.0
my_constants.omega   = (pi/3.0) / (300 * 4.40917904849092e-7)

# Use particle loader from file + dependency; this also updates the mesh for read_from_file
particles.B_ext_particle_init_style = "read_from_file"
particles.read_fields_from_path = "../../../../openPMD-example-datasets/example-femm-3d.h5"
particles.read_fields_B_dependency(t) = "cos(omega * t + phase_B)"

warpx.grid_type = collocated
warpx.do_electrostatic = labframe

#################################
####### GENERAL PARAMETERS ######
#################################
max_step = 300
amr.n_cell = 40 40 40
warpx.numprocs = 1 1 1
amr.max_level = 0
geometry.dims = 3

geometry.prob_lo =  -1.0  -1.0  0.0
geometry.prob_hi =   1.0   1.0  5.0

#################################
###### Boundary Condition #######
#################################
boundary.field_lo = pec pec pec
boundary.field_hi = pec pec pec
boundary.potential_lo_x = 0
boundary.potential_hi_x = 0
boundary.potential_lo_y = 0
boundary.potential_hi_y = 0
boundary.potential_lo_z = 0
boundary.potential_hi_z = 0

#################################
############ NUMERICS ###########
#################################
warpx.serialize_initial_conditions = 1
warpx.verbose = 1
warpx.const_dt = 4.40917904849092e-7
warpx.use_filter = 0

# Order of particle shape factors
algo.particle_shape = 1

